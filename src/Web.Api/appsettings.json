{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5433;Database=test4;Username=postgres;Password=123456;Include Error Detail=true",
    "AnalyticsDatabase": "Host=localhost;Port=5433;Database=acceso_ucsa_analytics;Username=postgres;Password=123456;Include Error Detail=true"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Secret": "super-duper-secret-value-that-should-be-in-user-secrets",
    "Issuer": "clean-architecture",
    "Audience": "developers",
    "ExpirationInMinutes": 60
  },
  "CookieConfigOptions": {
    "HttpOnly": true,
    "Secure": true,
    "SameSiteMode": 1
  }
}
